bridge:
  version: "1.0.0"

machine:
  machine_id: "CHANGE_ME"                    # e.g. "macbook-pro-office"
  machine_name: "CHANGE_ME"                  # e.g. "办公室 MacBook Pro"
  agent_type: "claude_code"                  # claude_code | openclaw | hermes_agent | codex
  agent_capability: "remote_execution"       # remote_execution | manual_only
  project_id: null                            # 关联的项目ID，不填则不关联项目

cloud:
  api_url: "http://localhost:8000/api/v1"
  api_key: "CHANGE_ME"
  poll_interval: 60                          # seconds

agent:
  # Agent CLI path resolution order (highest priority first):
  #   1. Environment variable  (e.g. DUS_CLAUDE_PATH)
  #   2. Configured path below (if set and differs from default)
  #   3. Auto-detect via PATH   (claude, codex, hermes, openclaw)
  #
  # Leave as default binary name (e.g. "claude") to auto-detect from PATH.
  path: "claude"
  workdir_template: "/tmp/dus_task_{task_id}"
  timeout: 3600

health:
  port: 19514                                 # local HTTP health port (0 to disable)

gc:
  enabled: true                               # periodic workspace cleanup
  interval: 3600                              # GC scan interval in seconds
  ttl: 86400                                  # delete workdirs older than this (seconds)

# Maximum concurrent tasks running in parallel
max_concurrent_tasks: 3

logging:
  level: "INFO"
